# Cisco IMC connection settings.
# Copy this file to ".env" and fill in real values.
# The .env file should never be committed to source control.

# IP address or hostname of the IMC web interface
IMC_HOST=192.168.1.106

# IMC user with privilege to read inventory and reset power
IMC_USERNAME=admin

# IMC password
IMC_PASSWORD=replace-me

# Most IMCs ship with self-signed certs; keep "false" unless you've installed
# a trusted certificate.
IMC_VERIFY_SSL=false

# HTTP timeout in seconds
IMC_TIMEOUT=30
